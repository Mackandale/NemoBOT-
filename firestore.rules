rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isAuthenticated() && 
        ((userDoc.exists && userDoc.data().roles.admin == true) ||
         (request.auth.token.email == "mackandaledardayes@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function fieldUnchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= minLen && 
             request.resource.data[field].size() <= maxLen;
    }
    
    function isValidBoolean(field) {
      return request.resource.data[field] is bool;
    }
    
    function isValidNumber(field, minVal, maxVal) {
      return request.resource.data[field] is number && 
             request.resource.data[field] >= minVal && 
             request.resource.data[field] <= maxVal;
    }
    
    function isValidTimestamp(field) {
      return request.resource.data[field] is timestamp;
    }
    
    function canAccessConversation(conversationId) {
      let convDoc = get(/databases/$(database)/documents/conversations/$(conversationId));
      return convDoc.exists && (convDoc.data().ownerUid == request.auth.uid || isAdmin());
    }

    // ===============================================================
    // User Profiles
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidString('name', 1, 100);
      allow update: if (isOwner(userId) || isAdmin()) && fieldUnchanged('uid') && isValidString('name', 1, 100);
    }

    // ===============================================================
    // Conversations
    // ===============================================================
    
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid && isValidString('title', 1, 200);
      allow update: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin()) && fieldUnchanged('ownerUid') && isValidString('title', 1, 200);
      allow delete: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ===============================================================
    // Messages
    // ===============================================================
    
    match /messages/{messageId} {
      allow read: if isAuthenticated() && canAccessConversation(resource.data.conversationId);
      allow create: if isAuthenticated() && canAccessConversation(request.resource.data.conversationId) && isValidString('content', 1, 5000);
      allow update: if isAuthenticated() && canAccessConversation(resource.data.conversationId) && fieldUnchanged('conversationId') && isValidString('content', 1, 5000);
      allow delete: if isAuthenticated() && canAccessConversation(resource.data.conversationId);
    }

    // ===============================================================
    // Memory
    // ===============================================================
    
    match /memory/{memoryId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidString('content', 1, 2000);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && fieldUnchanged('userId') && isValidString('content', 1, 2000);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ===============================================================
    // Global Memory
    // ===============================================================
    
    match /global_memory/{memoryId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    // ===============================================================
    // User Roles
    // ===============================================================
    
    match /user_roles/{email} {
      allow read: if isAuthenticated() && (request.auth.token.email == email || isAdmin());
      allow write: if isAdmin();
    }
  }
}
