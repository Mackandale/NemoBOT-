{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data including stats, settings, and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "roles": {
          "type": "object",
          "properties": {
            "user": { "type": "boolean" },
            "lazarus": { "type": "boolean" },
            "admin": { "type": "boolean" }
          }
        },
        "settings": {
          "type": "object",
          "properties": {
            "theme": { "type": "string" },
            "voice": { "type": "string" },
            "language": { "type": "string" },
            "personality": { "type": "string" },
            "zoomDisabled": { "type": "boolean" }
          }
        },
        "progression": {
          "type": "object",
          "properties": {
            "xp": { "type": "number" },
            "level": { "type": "number" },
            "rank": { "type": "string" },
            "activityScore": { "type": "number" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat conversation thread",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "pinned": { "type": "boolean" },
        "favorite": { "type": "boolean" }
      },
      "required": ["ownerUid", "title"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a conversation",
      "type": "object",
      "properties": {
        "conversationId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["conversationId", "role", "content", "timestamp"]
    },
    "Memory": {
      "title": "User Memory",
      "description": "Important information about the user stored for long-term context",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "importance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "importance"]
    },
    "UserRole": {
      "title": "User Role",
      "description": "Special roles assigned to users (e.g., lazarus)",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Chat conversations"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual chat messages"
    },
    "/memory/{memoryId}": {
      "schema": "Memory",
      "description": "User memories for AI context"
    },
    "/user_roles/{email}": {
      "schema": "UserRole",
      "description": "User special roles"
    }
  }
}
