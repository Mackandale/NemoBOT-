{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data including stats and settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "picture": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "level": { "type": "number" },
        "xp": { "type": "number" },
        "fcmToken": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Conversation": {
      "title": "Conversation Thread",
      "description": "A chat thread owned by a user",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "title"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a conversation",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "bot"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "image": { "type": "string" }
      },
      "required": ["role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Top-level conversations (used by client)"
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in top-level conversations"
    },
    "/users/{userId}/threads/{threadId}": {
      "schema": "Conversation",
      "description": "User-nested threads (used by server)"
    },
    "/users/{userId}/threads/{threadId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in user-nested threads"
    }
  }
}
